<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Edit Post</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body>
  <div class="w-full min-h-screen bg-zinc-900 text-white p-10">

    <!-- Back to Profile -->
    <div class="w-full flex justify-start mb-5">
      <a href="/profile"
         class="bg-blue-500 rounded-md px-3 py-2 text-sm">
        ← Back to Profile
      </a>
    </div>

    <h2 class="text-2xl mb-5">Edit Your Post</h2>

    <!-- Update Post Form -->
    <form action="/update/<%= post._id %>" method="POST">
      <textarea
        name="content"
        rows="5"
        class="w-1/3 p-3 resize-none bg-transparent border border-zinc-800 rounded-md outline-none"
      ><%= post.content %></textarea>

      <br>

      <input
        type="submit"
        value="Update Post"
        class="mt-3 px-3 py-2 bg-yellow-500 text-black rounded-md cursor-pointer"
      />
    </form>

  </div>
</body>
</html>
