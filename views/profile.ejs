<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Profile</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body>
  <div class="w-full min-h-screen bg-zinc-900 text-white p-10">

    <!-- Logout -->
    <div class="w-full flex justify-end">
      <a href="/logout"
         class="bg-red-500 rounded-md px-3 py-2 text-sm mb-5 inline-block">
        Logout
      </a>
    </div>

    <!-- Greeting -->
    <h3 class="text-3xl mb-2">
      <span class="font-light">Hello</span>, <%= user.name %>
    </h3>

    <h5 class="mb-5 text-zinc-400">You can create a new post</h5>

    <!-- Create Post -->
    <form action="/post" method="POST">
      <textarea
        name="content"
        placeholder="What's on your mind?"
        class="p-3 w-1/3 resize-none bg-transparent border border-zinc-800 outline-none rounded-md"
      ></textarea>

      <input
        type="submit"
        value="Create a new post"
        class="px-3 w-40 py-2 bg-blue-500 block rounded-md mt-2"
      />
    </form>

    <!-- Posts -->
    <div class="posts mt-20">
      <h3 class="text-zinc-400 mb-5">Your posts</h3>

      <div class="postcontainer">
        <% user.posts.reverse().forEach(function(post) { %>

          <div class="post w-1/3 p-4 mb-4 rounded-md border border-zinc-800">
            <h4 class="text-blue-500 mb-3">@<%= user.username %></h4>

            <p class="text-sm tracking-tight">
              <%= post.content %>
            </p>

            <small class="mt-3 inline-block text-zinc-400">
              <%= post.likes.length %> likes
            </small>

            <div class="btns flex gap-4 mt-3">
              <a class="text-blue-500" href="/like/<%= post._id %>">
                <%= post.likes.includes(user._id) ? "Unlike" : "Like" %>
              </a>

              <a class="text-zinc-500" href="/edit/<%= post._id %>">
                Edit
              </a>
            </div>
          </div>

        <% }) %>
      </div>
    </div>

  </div>
</body>
</html>
